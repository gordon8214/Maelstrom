<Dialog delegate="OptionsDialog">
	<Size w="496" h="348"/>
	<Elements>
		<DialogLabel name="title" text="Options">
			<Anchor anchorFrom="TOP" anchorTo="TOP" y="14"/>
		</DialogLabel>

		<DialogCheckbox name="autofire" bindValue="Gameplay.Autofire" text="Autofire (hold the fire key to fire continuously)">
			<Anchor anchorFrom="TOPLEFT" anchorTo="TOPLEFT" x="24" y="46"/>
		</DialogCheckbox>

		<DialogCheckbox name="autoshield" bindValue="Gameplay.AutoShield" text="Auto-shield (raise shields automatically near danger)">
			<Anchor anchorFrom="TOPLEFT" anchorTo="TOPLEFT" x="24" y="74"/>
		</DialogCheckbox>

		<DialogCheckbox name="interpolate" bindValue="InterpolateMotion" checked="true" text="Smooth motion (render at the display refresh rate)">
			<Anchor anchorFrom="TOPLEFT" anchorTo="TOPLEFT" x="24" y="102"/>
		</DialogCheckbox>

		<DialogLabel name="freqLabel" text="Powerup frequency:">
			<Anchor anchorFrom="TOPLEFT" anchorTo="TOPLEFT" x="24" y="134"/>
		</DialogLabel>

		<DialogRadioGroup name="prizeFreq" bindValue="Gameplay.PrizeFrequency">
			<Elements>
				<DialogRadioButton name="p100" text="100%" checked="true" id="100">
					<Anchor anchorFrom="TOPLEFT" anchorTo="TOPLEFT" x="34" y="160"/>
				</DialogRadioButton>
				<DialogRadioButton name="p200" text="200%" id="200">
					<Anchor anchorFrom="LEFT" anchorTo="RIGHT" anchor="p100" x="16"/>
				</DialogRadioButton>
				<DialogRadioButton name="p300" text="300%" id="300">
					<Anchor anchorFrom="LEFT" anchorTo="RIGHT" anchor="p200" x="16"/>
				</DialogRadioButton>
				<DialogRadioButton name="p400" text="400%" id="400">
					<Anchor anchorFrom="LEFT" anchorTo="RIGHT" anchor="p300" x="16"/>
				</DialogRadioButton>
				<DialogRadioButton name="p500" text="500%" id="500">
					<Anchor anchorFrom="LEFT" anchorTo="RIGHT" anchor="p400" x="16"/>
				</DialogRadioButton>
				<DialogRadioButton name="p600" text="600%" id="600">
					<Anchor anchorFrom="TOPLEFT" anchorTo="BOTTOMLEFT" anchor="p100" y="10"/>
				</DialogRadioButton>
				<DialogRadioButton name="p700" text="700%" id="700">
					<Anchor anchorFrom="TOPLEFT" anchorTo="BOTTOMLEFT" anchor="p200" y="10"/>
				</DialogRadioButton>
				<DialogRadioButton name="p800" text="800%" id="800">
					<Anchor anchorFrom="TOPLEFT" anchorTo="BOTTOMLEFT" anchor="p300" y="10"/>
				</DialogRadioButton>
				<DialogRadioButton name="p900" text="900%" id="900">
					<Anchor anchorFrom="TOPLEFT" anchorTo="BOTTOMLEFT" anchor="p400" y="10"/>
				</DialogRadioButton>
				<DialogRadioButton name="p1000" text="1000%" id="1000">
					<Anchor anchorFrom="TOPLEFT" anchorTo="BOTTOMLEFT" anchor="p500" y="10"/>
				</DialogRadioButton>
			</Elements>
		</DialogRadioGroup>

		<DialogLabel name="powerupLabel" text="Starting powerup:">
			<Anchor anchorFrom="TOPLEFT" anchorTo="TOPLEFT" x="24" y="222"/>
		</DialogLabel>

		<DialogRadioGroup name="startPowerup" bindValue="Gameplay.StartPowerup">
			<Elements>
				<DialogRadioButton name="pwNone" text="None" checked="true" id="0">
					<Anchor anchorFrom="TOPLEFT" anchorTo="TOPLEFT" x="34" y="248"/>
				</DialogRadioButton>
				<DialogRadioButton name="pwMachine" text="Machine Guns" id="1">
					<Anchor anchorFrom="TOPLEFT" anchorTo="TOPLEFT" x="190" y="248"/>
				</DialogRadioButton>
				<DialogRadioButton name="pwBrakes" text="Air Brakes" id="2">
					<Anchor anchorFrom="TOPLEFT" anchorTo="TOPLEFT" x="346" y="248"/>
				</DialogRadioButton>
				<DialogRadioButton name="pwTriple" text="Triple Fire" id="4">
					<Anchor anchorFrom="TOPLEFT" anchorTo="TOPLEFT" x="34" y="278"/>
				</DialogRadioButton>
				<DialogRadioButton name="pwLong" text="Long Range" id="8">
					<Anchor anchorFrom="TOPLEFT" anchorTo="TOPLEFT" x="190" y="278"/>
				</DialogRadioButton>
				<DialogRadioButton name="pwLucky" text="Lucky Irish" id="128">
					<Anchor anchorFrom="TOPLEFT" anchorTo="TOPLEFT" x="346" y="278"/>
				</DialogRadioButton>
			</Elements>
		</DialogRadioGroup>

		<DialogButton text="OK" default="true" id="1">
			<Anchor anchorFrom="BOTTOM" anchorTo="BOTTOM" y="-14"/>
		</DialogButton>
	</Elements>
</Dialog>
